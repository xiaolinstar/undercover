<view class="profile-container">
  <!-- 自定义导航栏 -->
  <view class="nav-bar">
    <view class="nav-back" bindtap="handleGoBack">
      <text class="back-icon">‹</text>
      <text class="back-text">返回</text>
    </view>
    <text class="nav-title">个人中心</text>
    <view class="nav-placeholder"></view>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-container">
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 主内容 -->
  <view wx:if="{{!loading}}" class="profile-content">
    <!-- 头部信息 -->
    <view class="profile-header">
      <image class="avatar" src="{{userInfo.avatar || '/assets/images/default-avatar.png'}}" />
      <text class="nickname">{{userInfo.nickname || '微信用户'}}</text>
    </view>

    <!-- 统计数据 -->
    <view class="stats-section">
      <view class="stat-item">
        <text class="stat-value">{{gamesPlayed}}</text>
        <text class="stat-label">总场次</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{gamesWon}}</text>
        <text class="stat-label">胜利</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{winRate}}%</text>
        <text class="stat-label">胜率</text>
      </view>
    </view>

    <!-- 退出登录按钮 -->
    <button class="logout-button" bindtap="handleLogout">退出登录</button>
  </view>
</view>
