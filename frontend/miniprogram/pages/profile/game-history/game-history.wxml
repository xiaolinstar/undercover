<view class="game-history-container">
  <!-- 自定义导航栏 -->
  <view class="nav-bar">
    <view class="nav-back" bindtap="handleGoBack">
      <text class="back-icon">‹</text>
      <text class="back-text">返回</text>
    </view>
    <text class="nav-title">游戏记录</text>
    <view class="nav-placeholder"></view>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-container">
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 游戏历史列表 -->
  <scroll-view 
    wx:if="{{!loading}}" 
    class="history-list" 
    scroll-y="true"
    enable-back-to-top="true"
    lower-threshold="50"
    bindscrolltolower="onReachBottom"
  >
    <view class="history-item" wx:for="{{gameHistory}}" wx:key="id">
      <view class="item-header">
        <text class="date">{{item.date}}</text>
        <view class="result-badge {{item.result === '胜利' ? 'win' : 'lose'}}">
          {{item.result}}
        </view>
      </view>
      <view class="item-body">
        <view class="detail-row">
          <text class="label">身份:</text>
          <text class="role {{item.role === '平民' ? 'civilian' : 'spy'}}">{{item.role}}</text>
        </view>
        <view class="detail-row">
          <text class="label">词语:</text>
          <text class="word">{{item.word}}</text>
        </view>
        <view class="detail-row">
          <text class="label">时长:</text>
          <text class="duration">{{item.duration}}</text>
        </view>
        <view class="detail-row">
          <text class="label">人数:</text>
          <text class="players">{{item.players}}人</text>
        </view>
      </view>
    </view>

    <!-- 加载更多提示 -->
    <view wx:if="{{hasMore}}" class="loading-more">
      <text class="loading-text">加载中...</text>
    </view>
    <view wx:if="{{!hasMore}}" class="no-more">
      <text class="no-more-text">没有更多记录了</text>
    </view>
  </scroll-view>
</view>