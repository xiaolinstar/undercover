# ========================================================
# 核心配置

# Flask 应用密钥 (用于 Session 等加密)
SECRET_KEY=your-secret-key-here

# Redis 连接 URL (格式: redis://:password@host:port/db)
REDIS_URL=redis://redis-server:6379/0

# 数据库连接 URL
SQLALCHEMY_DATABASE_URI=mysql+pymysql://undercover:undercover@mysql:3306/undercover

# ========================================================
# 微信公众号配置
# ========================================================
# 微信公众号 Token (用于服务器验证)
WECHAT_TOKEN=your_actual_wechat_token_here

# 微信公众号 AppID
WECHAT_APP_ID=your_actual_wechat_app_id_here

# 微信公众号 AppSecret
WECHAT_APP_SECRET=your_actual_wechat_app_secret_here

# 是否启用微信消息推送 (True/False)
ENABLE_WECHAT_PUSH=True

# ========================================================
# 微信小程序配置
# ========================================================
# 小程序 AppID
MINI_PROGRAM_APP_ID=your_miniprogram_app_id

# 小程序 AppSecret
MINI_PROGRAM_APP_SECRET=your_miniprogram_app_secret

# ========================================================
# 日志配置
# ========================================================
# 日志级别 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# 是否启用文件日志 (True/False)
# 如果启用，日志将写入 logs/app.log，并保留5个备份文件
ENABLE_FILE_LOGGING=False

# 日志目录 (可选，默认为 logs)
LOG_DIR=logs


# ========================================================
# WebSocket 配置
# ========================================================
# WebSocket 异步模式 (eventlet, threading, gevent)
SOCKETIO_ASYNC_MODE=eventlet

# WebSocket CORS 允许的源 (生产环境应限制具体域名，开发环境可用 *)
SOCKETIO_CORS_ALLOWED_ORIGINS=*

# 未来多实例扩展时使用（当前单实例部署不需要）
# SOCKETIO_MESSAGE_QUEUE=redis://redis-server:6379/1
