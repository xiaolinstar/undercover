<view class="edit-profile-container">
  <!-- 自定义导航栏 -->
  <view class="nav-bar">
    <view class="nav-back" bindtap="handleGoBack">
      <text class="back-icon">‹</text>
      <text class="back-text">取消</text>
    </view>
    <text class="nav-title">编辑资料</text>
    <view class="nav-placeholder"></view>
  </view>

  <view class="edit-content">
    <!-- 头像区域 -->
    <view class="avatar-section">
      <view class="avatar-wrapper" bindtap="onSelectAvatar">
        <image class="avatar" src="{{userInfo.avatar || '/assets/images/default-avatar.png'}}" />
        <view class="avatar-overlay">
          <text class="edit-icon">✎</text>
        </view>
      </view>
      <text class="avatar-tip">点击更换头像</text>
    </view>

    <!-- 昵称输入 -->
    <view class="input-section">
      <view class="input-item">
        <text class="input-label">昵称</text>
        <input 
          class="input-field" 
          placeholder="请输入昵称" 
          value="{{userInfo.nickname}}"
          bindinput="onNicknameChange"
        />
      </view>
    </view>

    <!-- 保存按钮 -->
    <button 
      class="save-button" 
      bindtap="onSaveChanges"
      disabled="{{uploading}}"
    >
      {{uploading ? '保存中...' : '保存'}}
    </button>
  </view>
</view>