# ========================================================
# 环境变量模板
# ========================================================
# 使用方法：
# 1. 根据环境创建特定环境变量文件：
#    - 开发环境：cp .env.example .env.development
#    - 预发布环境：cp .env.example .env.staging
#    - 生产环境：cp .env.example .env.production
# 2. 修改对应环境文件中的变量值
# 3. 部署时使用：
#    - 开发环境：docker-compose -f docker-compose.dev.yml up -d
#    - 预发布环境：docker compose --env-file backend/.env.staging up -d
#    - 生产环境：docker compose --env-file backend/.env.production up -d
# 4. 开发环境启动应用服务：source venv/bin/activate && python main.py
#    或指定环境启动：python main.py --env staging
#
# 说明：
# - Docker Compose 的 env_file 将环境变量注入到容器的环境变量中
# - 应用从 ENV_FILE 环境变量推导环境（从文件名推导）
# - .env.* 文件会被 .dockerignore 排除，不会进入容器
# - 本地开发时从 .env 文件读取配置，容器环境从环境变量读取配置
# - 无需手动设置 APP_ENV 环境变量，避免冗余

# ========================================================
# 核心配置
# ========================================================
# Flask 应用密钥 (用于 Session 等加密)
SECRET_KEY=your-secret-key-here

# Redis 连接 URL (格式: redis://:password@host:port/db)
# 开发环境：redis://localhost:6379/0
# 预发布/生产环境：redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0

# 数据库连接 URL
# 开发环境：mysql+pymysql://undercover:undercover@localhost:3306/undercover
# 预发布/生产环境：mysql+pymysql://undercover:undercover@mysql:3306/undercover
SQLALCHEMY_DATABASE_URI=mysql+pymysql://undercover:undercover@localhost:3306/undercover

# ========================================================
# 微信公众号配置
# ========================================================
# 微信公众号 Token (用于服务器验证)
WECHAT_TOKEN=your_actual_wechat_token_here

# 微信公众号 AppID
WECHAT_APP_ID=your_actual_wechat_app_id_here

# 微信公众号 AppSecret
WECHAT_APP_SECRET=your_actual_wechat_app_secret_here

# 是否启用微信消息推送 (True/False)
ENABLE_WECHAT_PUSH=True

# ========================================================
# 微信小程序配置
# ========================================================
# 小程序 AppID
MINI_PROGRAM_APP_ID=your_miniprogram_app_id

# 小程序 AppSecret
MINI_PROGRAM_APP_SECRET=your_miniprogram_app_secret

# ========================================================
# 日志配置
# ========================================================
# 日志级别 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# 是否启用文件日志 (True/False)
ENABLE_FILE_LOGGING=False

# 日志目录 (可选，默认为 logs)
LOG_DIR=logs

# ========================================================
# WebSocket 配置
# ========================================================
# WebSocket 异步模式 (eventlet, threading, gevent)
SOCKETIO_ASYNC_MODE=eventlet

# WebSocket CORS 允许的源 (生产环境应限制具体域名，开发环境可用 *)
SOCKETIO_CORS_ALLOWED_ORIGINS=*
